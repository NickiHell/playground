    "\n",
    "csv = pd.read_csv(r'../data/drugs.csv')\n",
    "\n",
    "sns.scatterplot(x=\"date\", y=\"value\", data=csv, c=csv[\"color\"])\n",
    "sns.lineplot(x=\"date\", y=\"value\", data=csv, linewidth=1.0)"
